    public void addEdge(int a, int b) {
        adjList[a].add(b);
        m++;
    }

    public void removeEdge(int a, int b) {
        if (!adjList[a].contains(b)) return;
        adjList[a].remove(b);
        m--;
    }

    public String toString() {
        String s = "";
        for(int i=0; i<n; i++)
            s += adjList[i] + "\n";
        return s;
    }

}
